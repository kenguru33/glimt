# versions.env — pinned tool versions for glimt modules
#
# Source this file in modules that install versioned binaries:
#
#   VERSIONS_ENV="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../../versions.env"
#   # shellcheck source=../../versions.env
#   source "$VERSIONS_ENV"
#
# Extras modules use:
#   VERSIONS_ENV="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../../../versions.env"

HELM_VERSION="v3.15.0"
NERDFONTS_VERSION="v3.0.2"
K9S_VERSION="v0.32.4"
GUM_VERSION="0.14.3"
KUBECTX_VERSION="v0.9.5"
LAZYDOCKER_VERSION="v0.23.3"
